---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdWrapper from '../components/AdWrapper.astro';

// Fetch today's data or latest data
const connectionsEntries = await getCollection('connections');
const pipsEntries = await getCollection('pips');

// Sort by date descending
const sortedConnections = connectionsEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedPips = pipsEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestConnection = sortedConnections[0];
const latestPip = sortedPips[0];
---

<Layout title="PuzzleCruise - Daily Hints for NYT Connections & Pips">
    <Header />
    
    <main class="flex-grow w-full max-w-6xl mx-auto px-4 py-8 space-y-12">
        <section class="text-center space-y-4 mb-12">
            <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white">
                NYT Games Hints Today
            </h1>
            <p class="text-gray-400 text-lg md:text-xl">
                Sail smoothly through daily hints without ruining the puzzle.
            </p>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Connections Section -->
            <section class="bg-[#111827] rounded-xl p-6 border border-gray-800 shadow-xl">
                <div class="mb-6 border-b border-gray-800 pb-4 flex justify-between items-center">
                    <h2 class="text-2xl font-bold text-gray-100 flex items-center gap-2">
                        <span class="text-orange-500">#</span> Connections
                    </h2>
                    <a href="/connections/" class="text-sm font-semibold text-orange-500 hover:text-orange-400 transition-colors">View Archive &rarr;</a>
                </div>
                
                {latestConnection ? (
                    <div class="flex flex-col h-full justify-between">
                        <div>
                            <div class="bg-gray-800/40 p-4 rounded-md mb-6 border border-gray-700 flex justify-between items-center">
                                <p class="text-sm text-gray-300 font-medium">Latest: <span class="text-white">{latestConnection.data.date.toISOString().split('T')[0]}</span></p>
                                <span class="px-2 py-1 bg-green-500/20 text-green-400 text-xs rounded font-bold uppercase tracking-wide">Live</span>
                            </div>
                            <AdWrapper />
                            <p class="text-gray-400 my-6">
                                Today's puzzle has been solved! Click below to view the exclusive, spoiler-free progressive hints and strategy guide.
                            </p>
                        </div>
                        <a href={`/connections/${latestConnection.id}`} class="block w-full text-center py-4 rounded-md font-bold text-white bg-orange-600 hover:bg-orange-500 transition-colors shadow-lg mt-4">
                            View Today's Hints & Strategy 🚀
                        </a>
                    </div>
                ) : (
                    <div class="flex flex-col items-center justify-center py-12 text-gray-500 bg-gray-900/30 rounded-lg border border-dashed border-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <p class="italic">Check back later for today's hints.</p>
                    </div>
                )}
            </section>
            
            <!-- Pips Section -->
            <section class="bg-[#111827] rounded-xl p-6 border border-gray-800 shadow-xl">
                <div class="mb-6 border-b border-gray-800 pb-4 flex justify-between items-center">
                    <h2 class="text-2xl font-bold text-gray-100 flex items-center gap-2">
                        <span class="text-blue-500">#</span> Pips
                    </h2>
                    <a href="/pips/" class="text-sm font-semibold text-blue-500 hover:text-blue-400 transition-colors">View Archive &rarr;</a>
                </div>
                
                {latestPip ? (
                    <div class="flex flex-col h-full justify-between">
                        <div>
                            <div class="bg-gray-800/40 p-4 rounded-md mb-6 border border-gray-700 flex justify-between items-center">
                                <p class="text-sm text-gray-300 font-medium">Latest: <span class="text-white">{latestPip.data.date.toISOString().split('T')[0]}</span></p>
                                <span class="px-2 py-1 bg-green-500/20 text-green-400 text-xs rounded font-bold uppercase tracking-wide">Live</span>
                            </div>
                            <p class="text-gray-400 my-6">
                                The domino layout for today's Pips has been analyzed. View the solution and step-by-step strategy.
                            </p>
                        </div>
                        <a href={`/pips/${latestPip.id}`} class="block w-full text-center py-4 rounded-md font-bold text-white bg-blue-600 hover:bg-blue-500 transition-colors shadow-lg mt-4">
                            View Today's Solution 🚀
                        </a>
                    </div>
                ) : (
                    <div class="flex flex-col items-center justify-center py-12 text-gray-500 bg-gray-900/30 rounded-lg border border-dashed border-gray-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <p class="italic">Check back later for today's Pips domino layouts.</p>
                    </div>
                )}
            </section>
        </div>

        <!-- Heavy SEO Content Sections (Anchors Domain Authority) -->
        <div class="mt-20 space-y-16 border-t border-gray-800 pt-16">
            <!-- Why Choose Us -->
            <section class="max-w-4xl mx-auto space-y-6">
                <h2 class="text-3xl font-bold text-gray-100">Why Use PuzzleCruise for NYT Connections Hints?</h2>
                <p class="text-gray-400 leading-relaxed text-lg">
                    If you are searching for <strong class="text-gray-300">NYT Connections hints today</strong>, you've likely found dozens of sites that immediately spoil the answers. At PuzzleCruise, we believe in preserving the thrill of the game. Our custom-built, <strong>progressive 3-stage hint system</strong> is designed to give you just enough of a nudge to solve the daily puzzle yourself without ruining the satisfaction of the "Aha!" moment.
                </p>
                <p class="text-gray-400 leading-relaxed text-lg">
                    Whether you're stuck on a tricky Purple category or just need a gentle push for the Yellow group, our daily updated Connections hints are carefully crafted by puzzle experts to help you maintain your winning streak.
                </p>
            </section>

            <!-- How to Play -->
            <section class="max-w-4xl mx-auto space-y-6">
                <h2 class="text-3xl font-bold text-gray-100">How to Play NYT Connections</h2>
                <div class="bg-[#111827] border border-gray-800 rounded-xl p-8 space-y-4 shadow-lg">
                    <p class="text-gray-400 leading-relaxed">
                        The New York Times Connections puzzle challenges players to group 16 words into four categories of four words each. Each category shares a specific theme or connection.
                    </p>
                    <ul class="list-disc list-inside text-gray-400 space-y-2 ml-4">
                        <li><strong class="text-yellow-400">Yellow Group:</strong> Typically the most straightforward category (e.g., "Types of Fruit").</li>
                        <li><strong class="text-green-400">Green Group:</strong> Medium difficulty, often involving light wordplay or trivia.</li>
                        <li><strong class="text-blue-400">Blue Group:</strong> Hard difficulty, usually involving cultural references, phrases, or specific associations.</li>
                        <li><strong class="text-purple-400">Purple Group:</strong> The trickiest category. It often relies on intense wordplay, missing letters, or fill-in-the-blank patterns (e.g., "Words starting with body parts").</li>
                    </ul>
                    <p class="text-gray-400 leading-relaxed mt-4">
                        You have exactly four mistakes to spare. Our <strong class="text-gray-300">Connections answers and strategies</strong> are updated daily to ensure you never waste a life on a deceptive crossover word!
                    </p>
                </div>
            </section>

            <!-- SEO FAQ Section for "People Also Ask" -->
            <section class="max-w-4xl mx-auto space-y-8 pb-12">
                <h2 class="text-3xl font-bold text-gray-100">Frequently Asked Questions</h2>
                
                <div class="space-y-6">
                    <div class="bg-gray-900/50 p-6 rounded-lg border border-gray-800">
                        <h3 class="text-xl font-bold text-gray-200 mb-2">What time does NYT Connections reset?</h3>
                        <p class="text-gray-400 leading-relaxed">
                            The New York Times Connections puzzle resets at exactly <strong>midnight local time</strong> every single day. This means players in regions like Australia and New Zealand gain access to the new puzzle before players in North America. We provide daily hints ahead of time so you're always prepared.
                        </p>
                    </div>

                    <div class="bg-gray-900/50 p-6 rounded-lg border border-gray-800">
                        <h3 class="text-xl font-bold text-gray-200 mb-2">Are these hints generated by AI?</h3>
                        <p class="text-gray-400 leading-relaxed">
                            Our hints are curated and written in a conversational, snarky, yet highly helpful tone. We use a combination of expert puzzle analysis and advanced AI tooling to break down the daily categories into safe, progressive clues that guide you to the solution without giving it away instantly.
                        </p>
                    </div>

                    <div class="bg-gray-900/50 p-6 rounded-lg border border-gray-800">
                        <h3 class="text-xl font-bold text-gray-200 mb-2">Is today's NYT Connections hard?</h3>
                        <p class="text-gray-400 leading-relaxed">
                            Difficulty fluctuates daily. Often, the puzzle setter includes "crossover" words—words that could seemingly belong to two or three different categories. Our daily strategy guide specifically calls out these deceptive traps before you make your first move.
                        </p>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <!-- JSON-LD Schema Markup for FAQ -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "What time does NYT Connections reset?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "The New York Times Connections puzzle resets at exactly midnight local time every single day. This means players in regions like Australia and New Zealand gain access to the new puzzle before players in North America. We provide daily hints ahead of time so you're always prepared."
                }
            },
            {
                "@type": "Question",
                "name": "Are these hints generated by AI?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Our hints are curated and written in a conversational, snarky, yet highly helpful tone. We use a combination of expert puzzle analysis and advanced AI tooling to break down the daily categories into safe, progressive clues that guide you to the solution without giving it away instantly."
                }
            },
            {
                "@type": "Question",
                "name": "Is today's NYT Connections hard?",
                "acceptedAnswer": {
                    "@type": "Answer",
                    "text": "Difficulty fluctuates daily. Often, the puzzle setter includes \"crossover\" words—words that could seemingly belong to two or three different categories. Our daily strategy guide specifically calls out these deceptive traps before you make your first move."
                }
            }
        ]
    })} />

    <Footer />
</Layout>
