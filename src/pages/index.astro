---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdWrapper from '../components/AdWrapper.astro';

// Fetch today's data or latest data
const connectionsEntries = await getCollection('connections');
const pipsEntries = await getCollection('pips');

// Sort by date descending
const sortedConnections = connectionsEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sortedPips = pipsEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestConnection = sortedConnections[0];
const latestPip = sortedPips[0];
---

<Layout title="PuzzleCruise - Daily Hints for NYT Connections & Pips">
    <Header />
    
    <main class="flex-grow w-full max-w-3xl mx-auto px-4 py-8 space-y-12">
        <section class="text-center space-y-4">
            <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">
                NYT Games Hints Today
            </h1>
            <p class="text-gray-400 text-lg">
                Sail smoothly through daily hints without ruining the puzzle.
            </p>
        </section>

        <!-- Connections Section -->
        <section>
            <div class="mb-4 border-b border-gray-800 pb-2 flex justify-between items-center">
                <h2 class="text-2xl font-bold text-gray-100">Connections</h2>
                <a href="/connections/" class="text-sm text-orange-500 hover:text-orange-400">View Archive &rarr;</a>
            </div>
            
            {latestConnection ? (
                <div class="prose prose-invert max-w-none">
                    <!-- Dynamic Client-Side Date Checker Logic can be added here, but for now we render latest -->
                    <div class="bg-gray-800/50 p-4 rounded-md mb-6 border border-gray-700">
                        <p class="text-sm text-gray-300 font-medium">Latest: {latestConnection.data.date.toISOString().split('T')[0]}</p>
                    </div>
                    <AdWrapper />
                    <!-- Render Content -->
                    <div set:html={latestConnection.rendered?.html} />
                </div>
            ) : (
                <p class="text-gray-500 italic">Check back later for today's hints.</p>
            )}
        </section>
        
        <!-- Pips Section (Placeholder) -->
        <section>
            <div class="mb-4 border-b border-gray-800 pb-2 flex justify-between items-center">
                <h2 class="text-2xl font-bold text-gray-100">Pips</h2>
                <a href="/pips/" class="text-sm text-orange-500 hover:text-orange-400">View Archive &rarr;</a>
            </div>
            
            {latestPip ? (
                <div class="prose prose-invert max-w-none">
                    <div class="bg-gray-800/50 p-4 rounded-md mb-6 border border-gray-700">
                        <p class="text-sm text-gray-300 font-medium">Latest: {latestPip.data.date.toISOString().split('T')[0]}</p>
                    </div>
                    <!-- Render Content -->
                    <div set:html={latestPip.rendered?.html} />
                </div>
            ) : (
                <p class="text-gray-500 italic">Check back later for today's Pips domino layouts.</p>
            )}
        </section>
    </main>

    <Footer />
</Layout>
